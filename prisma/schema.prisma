generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  color       String?
  parentId    String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  posts       Post[]
  sources     Source[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     PostTag[]
}

model Post {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String?
  featuredImage  String?
  categoryId     String
  templateType   String        @default("job")
  status         String        @default("draft")
  isFeatured     Boolean       @default(false)
  isBreaking     Boolean       @default(false)
  isTrending     Boolean       @default(false)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  canonicalUrl   String?
  viewCount      Int           @default(0)
  readTime       Int           @default(0)
  publishedAt    DateTime?
  expiredAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  category       Category      @relation(fields: [categoryId], references: [id])
  tags           PostTag[]
  importantDates ImportantDate[]
  importantLinks ImportantLink[]
}

model PostTag {
  postId    String
  tagId     String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model ImportantDate {
  id        String   @id @default(cuid())
  postId    String
  label     String
  date      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ImportantLink {
  id        String   @id @default(cuid())
  postId    String
  label     String
  url       String
  linkType  String   @default("general")
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Source {
  id            String    @id @default(cuid())
  name          String
  url           String
  sourceType    String    @default("rss")
  categoryId    String
  isActive      Boolean   @default(true)
  fetchInterval Int       @default(60)
  selectors     String?
  mappingRules  String?
  autoPublish   Boolean   @default(false)
  lastFetchedAt DateTime?
  lastStatus    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  category      Category  @relation(fields: [categoryId], references: [id])
  fetchLogs     FetchLog[]
}

model FetchLog {
  id           String   @id @default(cuid())
  sourceId     String
  status       String
  itemsFound   Int      @default(0)
  itemsCreated Int      @default(0)
  error        String?
  createdAt    DateTime @default(now())
  source       Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ad {
  id        String   @id @default(cuid())
  title     String
  code      String
  placement String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  altText   String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String?
  status    String   @default("draft")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
